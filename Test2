const undoStack=[], redoStack=[];
function saveUndo(){
    if(!appStarted)return;
    undoStack.push(myLayers.map(l=>({name:l.name,visible:l.visible,opacity:l.opacity,data:l.ctx.getImageData(0,0,canvasW,canvasH)})));
    if(undoStack.length>50)undoStack.shift();
    redoStack.length=0;
}
function restoreState(s){
    myLayers.forEach(l=>l.canvas.remove());myLayers=[];
    s.forEach(d=>{const l=createLayerCanvas(d.name);l.visible=d.visible;l.opacity=d.opacity;l.canvas.style.display=d.visible?'block':'none';l.canvas.style.opacity=d.opacity;l.ctx.putImageData(d.data,0,0);myLayers.push(l);});
    activeLayerIndex=Math.min(activeLayerIndex,myLayers.length-1);renderLayerPanel();
}
function undo(){if(!undoStack.length)return;redoStack.push(myLayers.map(l=>({name:l.name,visible:l.visible,opacity:l.opacity,data:l.ctx.getImageData(0,0,canvasW,canvasH)})));restoreState(undoStack.pop());}
function redo(){if(!redoStack.length)return;undoStack.push(myLayers.map(l=>({name:l.name,visible:l.visible,opacity:l.opacity,data:l.ctx.getImageData(0,0,canvasW,canvasH)})));restoreState(redoStack.pop());}

