<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Sadece Tanıdıklar</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: #0d0d1a; display: flex; flex-direction: column;
            height: 100vh; font-family: 'Segoe UI', sans-serif;
            overflow: hidden; touch-action: none; user-select: none;
        }

        #nameScreen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(135deg, #0d0d1a, #1a0a2e);
            display: flex; justify-content: center; align-items: center; z-index: 9999;
        }
        #nameScreen.hidden { display: none; }
        .name-box {
            background: #12122a; padding: 40px; border-radius: 20px;
            text-align: center; box-shadow: 0 8px 40px rgba(233,69,96,0.3);
            border: 1px solid #e94560; max-width: 400px; width: 90%;
        }
        .name-box h2 { color: #e94560; margin-bottom: 6px; }
        .name-box p { color: #a8a8b3; margin-bottom: 20px; font-size: 0.85em; }
        .name-box input {
            padding: 12px 20px; border-radius: 10px; border: 2px solid #e94560;
            background: #0d0d1a; color: white; font-size: 1.1em;
            text-align: center; width: 100%; outline: none;
        }
        .name-box input:focus { border-color: #4ecca3; }
        .name-box button {
            display: block; margin: 16px auto 0; padding: 12px 40px;
            border: none; border-radius: 10px; background: #e94560;
            color: white; font-size: 1em; font-weight: bold; cursor: pointer;
        }

        #header {
            display: flex; align-items: center; justify-content: space-between;
            width: 100%; padding: 3px 10px; background: #12122a;
            border-bottom: 1px solid #e94560; height: 32px; flex-shrink: 0;
        }
        #header h1 { color: #e94560; font-size: 0.95em; white-space: nowrap; }
        #status { color: #a8a8b3; font-size: 0.7em; display: flex; gap: 6px; align-items: center; }
        .online-count { color: #4ecca3; font-weight: bold; }

        #toolbar {
            display: flex; gap: 3px; padding: 3px 6px; background: #12122a;
            align-items: center; width: 100%; overflow-x: auto; overflow-y: hidden;
            border-bottom: 1px solid #1a1a3e; flex-shrink: 0; height: 38px;
        }
        #toolbar::-webkit-scrollbar { height: 2px; }
        #toolbar::-webkit-scrollbar-thumb { background: #e94560; }
        #toolbar label { color: #a8a8b3; font-size: 0.65em; white-space: nowrap; }
        #toolbar input[type="color"] {
            width: 26px; height: 26px; border: 2px solid #e94560;
            border-radius: 50%; cursor: pointer; background: none; padding: 1px; flex-shrink: 0;
        }
        #toolbar input[type="range"] { width: 60px; accent-color: #e94560; flex-shrink: 0; }
        .btn {
            padding: 3px 7px; border: none; border-radius: 5px; cursor: pointer;
            font-size: 0.65em; font-weight: 600; white-space: nowrap; flex-shrink: 0;
        }
        .btn:active { transform: scale(0.95); }
        .btn-danger { background: #e94560; color: white; }
        .btn-primary { background: #0f3460; color: #e94560; border: 1px solid #e94560; }
        .btn-primary:hover, .btn-primary.active { background: #e94560; color: white; }
        .sep { width: 1px; height: 22px; background: #333; flex-shrink: 0; }
        #sizePreview { width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        #sizePreviewDot { border-radius: 50%; background: #e94560; }

        #mainArea { display: flex; flex: 1; overflow: hidden; position: relative; }
        #canvasContainer { position: relative; flex: 1; cursor: none; overflow: hidden; }
        canvas { position: absolute; top: 0; left: 0; }
        #bgCanvas { z-index: 0; }
        .layer-canvas { z-index: 1; }
        .remote-canvas { z-index: 2; }
        #shapePreview { z-index: 99; pointer-events: none; }
        #cursorCanvas { z-index: 100; pointer-events: none; }

        #colorPalette { display: flex; gap: 2px; flex-shrink: 0; align-items: center; }
        .palette-color {
            width: 16px; height: 16px; border-radius: 50%; cursor: pointer;
            border: 2px solid transparent;
        }
        .palette-color:hover, .palette-color.active { border-color: white; }

        /* Chat */
        #chatPanel {
            width: 0; background: #12122a; border-left: 1px solid #e94560;
            display: flex; flex-direction: column; transition: width 0.3s;
            overflow: hidden; flex-shrink: 0;
        }
        #chatPanel.open { width: 260px; }
        @media(max-width:600px) { #chatPanel.open { width: 200px; } }
        #chatHeader {
            padding: 8px 10px; border-bottom: 1px solid #1a1a3e;
            display: flex; justify-content: space-between; align-items: center; flex-shrink: 0;
        }
        #chatHeader h3 { color: #e94560; font-size: 0.85em; }
        #chatClose { background: none; border: none; color: #e94560; cursor: pointer; font-size: 1.2em; }
        #chatMessages {
            flex: 1; overflow-y: auto; padding: 8px; display: flex;
            flex-direction: column; gap: 4px;
        }
        #chatMessages::-webkit-scrollbar { width: 4px; }
        #chatMessages::-webkit-scrollbar-thumb { background: #e94560; border-radius: 4px; }
        .chat-msg { padding: 5px 8px; border-radius: 8px; font-size: 0.72em; background: #1a1a3e; word-wrap: break-word; }
        .chat-msg .chat-name { font-weight: bold; margin-right: 4px; }
        .chat-msg .chat-time { color: #555; font-size: 0.75em; margin-left: 4px; }
        .chat-msg.system { color: #4ecca3; font-style: italic; background: rgba(78,204,163,0.08); }
        #chatInputArea { display: flex; gap: 4px; padding: 6px; border-top: 1px solid #1a1a3e; flex-shrink: 0; }
        #chatInput {
            flex: 1; padding: 6px 10px; border-radius: 8px; border: 1px solid #333;
            background: #0d0d1a; color: white; font-size: 0.8em; outline: none;
        }
        #chatInput:focus { border-color: #e94560; }
        #chatSendBtn { padding: 6px 12px; border: none; border-radius: 8px; background: #e94560; color: white; cursor: pointer; font-size: 0.8em; }

        #chatToggle {
            position: absolute; right: 10px; bottom: 10px; z-index: 300;
            width: 44px; height: 44px; border-radius: 50%; border: 2px solid #e94560;
            background: #12122a; color: #e94560; font-size: 1.3em; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
        }
        #chatBadge {
            position: absolute; top: -4px; right: -4px; width: 18px; height: 18px;
            background: #ff4444; border-radius: 50%; font-size: 0.55em; color: white;
            display: none; align-items: center; justify-content: center; font-weight: bold;
        }

        /* Layer Panel */
        #layerPanel {
            position: absolute; right: 60px; top: 8px;
            background: rgba(18,18,42,0.95); border: 1px solid #e94560;
            border-radius: 10px; padding: 8px; z-index: 200;
            min-width: 160px; max-height: 280px; display: none; backdrop-filter: blur(10px);
        }
        #layerPanel.show { display: block; }
        #layerPanel h3 { color: #e94560; font-size: 0.8em; margin-bottom: 6px; text-align: center; }
        .layer-item {
            display: flex; align-items: center; gap: 4px; padding: 3px 5px;
            border-radius: 5px; cursor: pointer; font-size: 0.68em; color: #ccc;
        }
        .layer-item:hover { background: rgba(233,69,96,0.1); }
        .layer-item.active { background: rgba(233,69,96,0.25); border: 1px solid #e94560; }
        .layer-item input[type="checkbox"] { accent-color: #e94560; }
        .layer-item .layer-name { flex: 1; }
        .layer-btn { padding: 2px 5px; font-size: 0.6em; border: none; border-radius: 3px; cursor: pointer; background: #e94560; color: white; }
        .layer-controls { display: flex; gap: 3px; margin-top: 5px; justify-content: center; flex-wrap: wrap; }

        /* SIMPLE Online Modal */
        #modal {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9); display: flex;
            justify-content: center; align-items: center; z-index: 1000;
        }
        #modal.hidden { display: none; }
        .modal-content {
            background: #12122a; padding: 24px; border-radius: 16px;
            text-align: center; max-width: 420px; width: 92%;
            box-shadow: 0 8px 32px rgba(233,69,96,0.3);
        }
        .modal-content h2 { color: #e94560; margin-bottom: 12px; }
        .modal-content p { color: #a8a8b3; margin-bottom: 12px; font-size: 0.82em; line-height: 1.5; }
        .step-box {
            background: #0d0d1a; border: 1px solid #333; border-radius: 12px;
            padding: 16px; margin: 10px 0; text-align: left;
        }
        .step-box h4 { color: #4ecca3; font-size: 0.85em; margin-bottom: 8px; }
        .step-box p { font-size: 0.75em; color: #888; margin-bottom: 6px; }
        .code-area {
            width: 100%; height: 60px; background: #1a1a3e; border: 1px solid #e94560;
            color: white; border-radius: 8px; padding: 8px; font-size: 0.65em;
            resize: none; font-family: monospace;
        }
        .big-btn {
            padding: 12px 28px; border: none; border-radius: 10px;
            font-size: 1em; font-weight: bold; cursor: pointer; margin: 4px;
        }
        .big-btn.red { background: #e94560; color: white; }
        .big-btn.blue { background: #0f3460; color: #e94560; border: 2px solid #e94560; }
        .big-btn:hover { transform: scale(1.03); }
        .step-num {
            display: inline-block; width: 24px; height: 24px; border-radius: 50%;
            background: #e94560; color: white; text-align: center; line-height: 24px;
            font-size: 0.75em; font-weight: bold; margin-right: 6px;
        }
        .copy-btn {
            padding: 4px 12px; border: none; border-radius: 6px;
            background: #4ecca3; color: #000; cursor: pointer; font-size: 0.75em;
            font-weight: bold; margin-top: 6px;
        }

        /* Toast */
        #toast {
            position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%);
            background: rgba(233,69,96,0.95); color: white; padding: 12px 24px;
            border-radius: 10px; font-weight: bold; z-index: 9999;
            display: none; pointer-events: none;
        }
        @keyframes toastAnim {
            0% { opacity:0; transform: translate(-50%,-50%) scale(0.8); }
            15% { opacity:1; transform: translate(-50%,-50%) scale(1); }
            85% { opacity:1; } 100% { opacity:0; }
        }

        /* Players list */
        #playersList {
            position: absolute; left: 10px; top: 10px; z-index: 200;
            display: flex; flex-direction: column; gap: 3px; pointer-events: none;
        }
        .player-tag {
            padding: 2px 8px; border-radius: 6px; font-size: 0.65em;
            color: white; font-weight: bold; display: flex; align-items: center; gap: 4px;
        }
        .player-dot { width: 8px; height: 8px; border-radius: 50%; }
    </style>
</head>
<body>

<div id="nameScreen">
    <div class="name-box">
        <h2>🎨 Sadece Tanıdıklar</h2>
        <p>Enter your name to start</p>
        <input type="text" id="nameInput" placeholder="Your name..." maxlength="16" autofocus>
        <button id="nameSubmitBtn">Start Drawing →</button>
    </div>
</div>

<div id="header">
    <h1>🎨 Sadece Tanıdıklar</h1>
    <div id="status">
        <span id="connectionStatus">Offline</span> |
        👥 <span class="online-count" id="playerCount">1</span>/12
    </div>
</div>

<div id="toolbar">
    <input type="color" id="colorPicker" value="#e94560">
    <div id="colorPalette"></div>
    <div class="sep"></div>
    <label>Size:</label>
    <input type="range" id="sizePicker" min="1" max="80" value="4">
    <div id="sizePreview"><div id="sizePreviewDot"></div></div>
    <div class="sep"></div>
    <label>Opacity:</label>
    <input type="range" id="opacityPicker" min="5" max="100" value="100">
    <div class="sep"></div>
    <button class="btn btn-primary active" id="brushBtn">✏️</button>
    <button class="btn btn-primary" id="eraserBtn">🧹</button>
    <button class="btn btn-primary" id="rectBtn">▭</button>
    <button class="btn btn-primary" id="circleBtn">⬭</button>
    <button class="btn btn-primary" id="lineBtn">╱</button>
    <button class="btn btn-primary" id="fillBucketBtn">🪣</button>
    <button class="btn btn-primary" id="eyedropperBtn">💧</button>
    <button class="btn btn-primary" id="textBtn">T</button>
    <button class="btn btn-primary" id="sprayBtn">⊹</button>
    <div class="sep"></div>
    <button class="btn btn-primary" id="fillToggle">Fill:Off</button>
    <button class="btn btn-primary" id="dashToggle">Dash:Off</button>
    <button class="btn btn-primary" id="mirrorToggle">Mirror:Off</button>
    <button class="btn btn-primary" id="gridToggle">Grid:Off</button>
    <div class="sep"></div>
    <button class="btn btn-primary" id="undoBtn">↩</button>
    <button class="btn btn-primary" id="redoBtn">↪</button>
    <button class="btn btn-danger" id="clearBtn">🗑️Mine</button>
    <div class="sep"></div>
    <button class="btn btn-primary" id="layerBtn">📑</button>
    <button class="btn btn-primary" id="saveBtn">💾</button>
    <button class="btn btn-primary" id="connectBtn">🌐</button>
</div>

<div id="mainArea">
    <div id="canvasContainer">
        <canvas id="bgCanvas"></canvas>
        <canvas id="shapePreview"></canvas>
        <canvas id="cursorCanvas"></canvas>
        <div id="playersList"></div>
        <div id="layerPanel">
            <h3>📑 Layers</h3>
            <div id="layerList"></div>
            <div class="layer-controls">
                <button class="layer-btn" id="addLayerBtn">+</button>
                <button class="layer-btn" id="delLayerBtn">-</button>
                <button class="layer-btn" id="mergeLayerBtn">⤵</button>
                <button class="layer-btn" id="dupLayerBtn">⧉</button>
                <button class="layer-btn" id="moveUpBtn">↑</button>
                <button class="layer-btn" id="moveDownBtn">↓</button>
            </div>
        </div>
        <button id="chatToggle">💬<span id="chatBadge">0</span></button>
    </div>

    <div id="chatPanel">
        <div id="chatHeader"><h3>💬 Chat</h3><button id="chatClose">✕</button></div>
        <div id="chatMessages"></div>
        <div id="chatInputArea">
            <input type="text" id="chatInput" placeholder="Message..." maxlength="200">
            <button id="chatSendBtn">▶</button>
        </div>
    </div>
</div>

<div id="toast"></div>

<!-- SIMPLIFIED ONLINE MODAL -->
<div id="modal" class="hidden">
    <div class="modal-content">
        <h2>🌐 Connect Online</h2>
        <p>Up to 12 players! One person creates, others join.</p>

        <!-- HOST VIEW -->
        <div id="hostView" style="display:none">
            <div class="step-box">
                <h4><span class="step-num">1</span> Your Room Code</h4>
                <p>Send this code to your friends (copy the text below):</p>
                <textarea class="code-area" id="hostCode" readonly></textarea>
                <button class="copy-btn" id="copyHostCode">📋 Copy My Code</button>
            </div>
            <div class="step-box">
                <h4><span class="step-num">2</span> Paste Friend's Reply</h4>
                <p>When a friend sends back their reply code, paste it here:</p>
                <textarea class="code-area" id="hostAnswerInput" placeholder="Paste friend's reply here..."></textarea>
                <button class="copy-btn" id="acceptFriendReply" style="background:#e94560;color:white">✅ Connect Friend</button>
            </div>
            <p style="font-size:0.7em;color:#666;margin-top:8px">Repeat step 2 for each friend (up to 11 more)</p>
        </div>

        <!-- JOIN VIEW -->
        <div id="joinView" style="display:none">
            <div class="step-box">
                <h4><span class="step-num">1</span> Paste Host's Code</h4>
                <p>Get the code from whoever created the room:</p>
                <textarea class="code-area" id="joinOfferInput" placeholder="Paste the host's code here..."></textarea>
                <button class="copy-btn" id="processJoinCode" style="background:#e94560;color:white">🔗 Generate My Reply</button>
            </div>
            <div class="step-box" id="joinStep2" style="display:none">
                <h4><span class="step-num">2</span> Send This Reply Back</h4>
                <p>Copy this and send it back to the host:</p>
                <textarea class="code-area" id="joinAnswerOutput" readonly></textarea>
                <button class="copy-btn" id="copyJoinAnswer">📋 Copy My Reply</button>
            </div>
        </div>

        <!-- INITIAL CHOICE -->
        <div id="choiceView">
            <button class="big-btn red" id="createBtn">📡 Create Room</button>
            <button class="big-btn blue" id="joinBtn">🔗 Join Room</button>
        </div>

        <div style="margin-top:14px">
            <button class="btn btn-primary" id="backToChoice" style="display:none">← Back</button>
            <button class="btn btn-primary" id="closeModalBtn">Close</button>
        </div>
    </div>
</div>

<script>
// ================================================================
//  SADECE TANIDILAR v5 — Fixed, Multi-peer, Protected
// ================================================================

// ===== DEVICE =====
const isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);

// ===== BLOCK MIDDLE MOUSE =====
window.addEventListener('mousedown', e => { if(e.button===1){e.preventDefault();e.stopPropagation();} }, true);
window.addEventListener('auxclick', e => { e.preventDefault(); e.stopPropagation(); }, true);
window.addEventListener('contextmenu', e => e.preventDefault());

// ===== GLOBALS =====
const containerEl = document.getElementById('canvasContainer');
const bgCanvas = document.getElementById('bgCanvas');
const bgCtx = bgCanvas.getContext('2d');
const cursorCanvas = document.getElementById('cursorCanvas');
const cursorCtx = cursorCanvas.getContext('2d');
const shapePreview = document.getElementById('shapePreview');
const shapeCtx = shapePreview.getContext('2d');
let canvasW = 100, canvasH = 100, appStarted = false;

// ===== IDENTITY =====
const myId = crypto.randomUUID ? crypto.randomUUID() : 'P_'+Math.random().toString(36).substr(2,10);
const myHue = Math.floor(Math.random()*360);
const myColor = `hsl(${myHue},80%,60%)`;
let myName = '';

// ===== RATE LIMITING (DDoS protection) =====
const rateLimiter = {
    counts: {},
    lastReset: Date.now(),
    MAX_PER_SECOND: 200,
    check(peerId) {
        const now = Date.now();
        if (now - this.lastReset > 1000) { this.counts = {}; this.lastReset = now; }
        this.counts[peerId] = (this.counts[peerId]||0) + 1;
        return this.counts[peerId] <= this.MAX_PER_SECOND;
    }
};

// Message size limit
const MAX_MSG_SIZE = 500000; // 500KB

// ===== NAME =====
const nameScreen = document.getElementById('nameScreen');
const nameInputEl = document.getElementById('nameInput');
const sn = localStorage.getItem('st_name');
if (sn) nameInputEl.value = sn;

function submitName() {
    const n = nameInputEl.value.trim();
    if (!n) { nameInputEl.style.borderColor='#ff4444'; return; }
    myName = n;
    localStorage.setItem('st_name', myName);
    nameScreen.classList.add('hidden');
    appStarted = true;
    initApp();
}
document.getElementById('nameSubmitBtn').addEventListener('click', submitName);
nameInputEl.addEventListener('keydown', e => { if(e.key==='Enter') submitName(); nameInputEl.style.borderColor='#e94560'; });

// ===== PALETTE =====
const paletteColors = ['#000','#fff','#e94560','#ff6b6b','#ffa502','#ffdd59','#4ecca3','#2ed573','#1e90ff','#3742fa','#a55eea','#ff6348','#7f8c8d','#fd79a8','#00cec9','#6c5ce7'];
const paletteEl = document.getElementById('colorPalette');
paletteColors.forEach(c => {
    const d = document.createElement('div');
    d.className = 'palette-color'; d.style.background = c;
    d.addEventListener('click', () => {
        currentColor = c; colorPicker.value = c.length===4 ?
            '#'+c[1]+c[1]+c[2]+c[2]+c[3]+c[3] : c;
        updateSizePreview();
        if (currentTool==='eraser') setTool('brush');
        paletteEl.querySelectorAll('.palette-color').forEach(p=>p.classList.remove('active'));
        d.classList.add('active');
    });
    paletteEl.appendChild(d);
});

// ===== LAYERS =====
let myLayers = [], activeLayerIndex = 0;
const remoteCanvases = {};

function createLayerCanvas(name) {
    const c = document.createElement('canvas');
    c.className = 'layer-canvas'; c.width = canvasW; c.height = canvasH; c.style.zIndex = 1;
    containerEl.insertBefore(c, shapePreview);
    const ctx = c.getContext('2d'); ctx.lineCap='round'; ctx.lineJoin='round';
    return { name, canvas:c, ctx, visible:true, opacity:1 };
}

function getOrCreateRemoteCanvas(pid) {
    if (remoteCanvases[pid]) return remoteCanvases[pid];
    const c = document.createElement('canvas');
    c.className = 'remote-canvas'; c.width = canvasW; c.height = canvasH; c.style.zIndex = 2;
    containerEl.insertBefore(c, shapePreview);
    const ctx = c.getContext('2d'); ctx.lineCap='round'; ctx.lineJoin='round';
    remoteCanvases[pid] = { canvas:c, ctx };
    return remoteCanvases[pid];
}

function initMyLayers() {
    myLayers.forEach(l=>l.canvas.remove()); myLayers = [];
    myLayers.push(createLayerCanvas('Layer 1')); activeLayerIndex = 0;
    renderLayerPanel();
}

function getActiveCtx() { return myLayers[activeLayerIndex].ctx; }

function renderLayerPanel() {
    const list = document.getElementById('layerList'); list.innerHTML = '';
    for (let i=myLayers.length-1;i>=0;i--) {
        const l=myLayers[i];
        const item=document.createElement('div');
        item.className='layer-item'+(i===activeLayerIndex?' active':'');
        item.innerHTML=`<input type="checkbox" ${l.visible?'checked':''} data-i="${i}">
            <span class="layer-name">${l.name}</span>
            <input type="range" class="layer-opacity" min="0" max="100" value="${Math.round(l.opacity*100)}" data-i="${i}" style="width:40px">`;
        item.addEventListener('click', e=>{if(e.target.tagName==='INPUT')return;activeLayerIndex=i;renderLayerPanel();});
        list.appendChild(item);
    }
    list.querySelectorAll('input[type="checkbox"]').forEach(cb=>{
        cb.addEventListener('change',e=>{const i=+e.target.dataset.i;myLayers[i].visible=e.target.checked;myLayers[i].canvas.style.display=e.target.checked?'block':'none';});
    });
    list.querySelectorAll('.layer-opacity').forEach(s=>{
        s.addEventListener('input',e=>{const i=+e.target.dataset.i;myLayers[i].opacity=+e.target.value/100;myLayers[i].canvas.style.opacity=myLayers[i].opacity;});
    });
}

document.getElementById('addLayerBtn').addEventListener('click',()=>{myLayers.push(createLayerCanvas('Layer '+(myLayers.length+1)));activeLayerIndex=myLayers.length-1;renderLayerPanel();saveUndo();});
