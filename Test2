// ===== CURSOR RENDER =====
const cursorTargets={}, cursorSmooth={};
const LERP=0.45;

function renderCursors(){
    for(const id in cursorTargets){
        const t=cursorTargets[id];
        if(!cursorSmooth[id])cursorSmooth[id]={...t};
        else{const s=cursorSmooth[id];s.x+=(t.x-s.x)*LERP;s.y+=(t.y-s.y)*LERP;s.c=t.c;s.n=t.n;s.ls=t.ls;}
    }
    cursorCtx.clearRect(0,0,canvasW,canvasH);
    if(!appStarted){requestAnimationFrame(renderCursors);return;}
    const now=Date.now();

    // Own cursor
    if(myCursorIn&&myCursorPos.x>-50){
        const x=myCursorPos.x,y=myCursorPos.y;
        cursorCtx.save();
        const sz=currentTool==='eraser'?currentSize*2.5:currentSize;
        const rad=Math.max(sz/2,3);
        cursorCtx.beginPath();cursorCtx.arc(x,y,rad,0,Math.PI*2);
        cursorCtx.strokeStyle=currentTool==='eraser'?'#aaa':currentColor;
        cursorCtx.lineWidth=2;cursorCtx.stroke();
        cursorCtx.beginPath();cursorCtx.arc(x,y,1.5,0,Math.PI*2);cursorCtx.fillStyle='#fff';cursorCtx.fill();
        const g=rad+3,ln=6;cursorCtx.beginPath();
        cursorCtx.moveTo(x-g,y);cursorCtx.lineTo(x-g-ln,y);cursorCtx.moveTo(x+g,y);cursorCtx.lineTo(x+g+ln,y);
        cursorCtx.moveTo(x,y-g);cursorCtx.lineTo(x,y-g-ln);cursorCtx.moveTo(x,y+g);cursorCtx.lineTo(x,y+g+ln);
        cursorCtx.strokeStyle='rgba(255,255,255,0.5)';cursorCtx.lineWidth=1;cursorCtx.stroke();
        cursorCtx.font='bold 11px sans-serif';const tw=cursorCtx.measureText(myName).width;
        cursorCtx.globalAlpha=0.85;cursorCtx.fillStyle=myColor;
        cursorCtx.beginPath();cursorCtx.roundRect(x+rad+8,y-rad-16,tw+12,20,5);cursorCtx.fill();
        cursorCtx.globalAlpha=1;cursorCtx.fillStyle='#fff';cursorCtx.fillText(myName,x+rad+14,y-rad-1);
        cursorCtx.restore();
    }

    // Remote
    for(const[id,cur]of Object.entries(cursorSmooth)){
        if(id===myId)continue;
        if(now-cur.ls>8000){delete cursorSmooth[id];delete cursorTargets[id];continue;}
        const x=cur.x*canvasW,y=cur.y*canvasH,color=cur.c||'#0f0';
        cursorCtx.save();cursorCtx.translate(x,y);
        cursorCtx.shadowColor=color;cursorCtx.shadowBlur=5;
        cursorCtx.beginPath();cursorCtx.moveTo(0,0);cursorCtx.lineTo(0,21);cursorCtx.lineTo(5,17);cursorCtx.lineTo(10,25);cursorCtx.lineTo(13.5,23);cursorCtx.lineTo(8.5,15);cursorCtx.lineTo(14,15);cursorCtx.closePath();
        cursorCtx.fillStyle=color;cursorCtx.fill();cursorCtx.shadowBlur=0;cursorCtx.strokeStyle='#000';cursorCtx.lineWidth=1;cursorCtx.stroke();
        const name=cur.n||id;cursorCtx.font='bold 11px sans-serif';const tw=cursorCtx.measureText(name).width;
        cursorCtx.globalAlpha=0.9;cursorCtx.fillStyle=color;cursorCtx.beginPath();cursorCtx.roundRect(16,18,tw+12,20,5);cursorCtx.fill();
        cursorCtx.globalAlpha=1;cursorCtx.fillStyle='#fff';cursorCtx.fillText(name,22,33);
        cursorCtx.restore();
    }

    updatePlayersList();
    requestAnimationFrame(renderCursors);
}

// ===== PLAYERS LIST =====
function updatePlayersList(){
    const el=document.getElementById('playersList');el.innerHTML='';
    const now=Date.now();let count=1;
    // Me
    el.innerHTML=`<div class="player-tag" style="background:${myColor}40"><div class="player-dot" style="background:${myColor}"></div>${esc(myName)} (you)</div>`;
    for(const[id,c]of Object.entries(cursorTargets)){
        if(id===myId)continue;
        if(now-c.ls>8000)continue;
        count++;
        el.innerHTML+=`<div class="player-tag" style="background:${c.c}40"><div class="player-dot" style="background:${c.c}"></div>${esc(c.n||id)}</div>`;
    }
    document.getElementById('playerCount').textContent=count;
}
function esc(s){const d=document.createElement('div');d.textContent=s;return d.innerHTML;}

// ===== CHAT =====
const chatPanel=document.getElementById('chatPanel');
const chatMessages=document.getElementById('chatMessages');
const chatInput=document.getElementById('chatInput');
let chatOpen=false, unread=0;

document.getElementById('chatToggle').addEventListener('click',()=>{
    chatOpen=!chatOpen;chatPanel.classList.toggle('open',chatOpen);
    if(chatOpen){unread=0;document.getElementById('chatBadge').style.display='none';chatInput.focus();}
    setTimeout(resizeAll,350);
});
document.getElementById('chatClose').addEventListener('click',()=>{chatOpen=false;chatPanel.classList.remove('open');setTimeout(resizeAll,350);});

function sendChat(){const m=chatInput.value.trim();if(!m)return;chatInput.value='';const d={type:'chat',sid:myId,n:myName,c:myColor,t:m,ts:Date.now()};broadcast(d);addChat(d);}
document.getElementById('chatSendBtn').addEventListener('click',sendChat);
chatInput.addEventListener('keydown',e=>{if(e.key==='Enter')sendChat();});

function addChat(d){
    const div=document.createElement('div');div.className='chat-msg';
    const time=new Date(d.ts).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
    div.innerHTML=`<span class="chat-name" style="color:${d.c}">${esc(d.n)}:</span> ${esc(d.t)}<span class="chat-time">${time}</span>`;
    chatMessages.appendChild(div);chatMessages.scrollTop=chatMessages.scrollHeight;
    if(!chatOpen&&d.sid!==myId){unread++;const b=document.getElementById('chatBadge');b.textContent=unread;b.style.display='flex';}
}
function sysMsg(t){const d=document.createElement('div');d.className='chat-msg system';d.textContent=t;chatMessages.appendChild(d);chatMessages.scrollTop=chatMessages.scrollHeight;}

// ===== MESSAGE HANDLER =====
function handleMsg(data, peerId){
    // Rate limit check
    if(peerId && !rateLimiter.check(peerId)) return;
    // Size check already done at receive

    if(data.type==='d'&&data.sid&&data.sid!==myId){
        const rc=getOrCreateRemoteCanvas(data.sid);
        drawLine(rc.ctx,data.x1*canvasW,data.y1*canvasH,data.x2*canvasW,data.y2*canvasH,data.c,data.s,!!data.e,data.o);
    }
    else if(data.type==='spray'&&data.sid&&data.sid!==myId){
        const rc=getOrCreateRemoteCanvas(data.sid);
        drawSpray(rc.ctx,data.x*canvasW,data.y*canvasH,data.c,data.s,data.o);
    }
    else if(data.type==='sh'&&data.sid&&data.sid!==myId){
        const rc=getOrCreateRemoteCanvas(data.sid);
        drawShape(rc.ctx,data.t,data.x1*canvasW,data.y1*canvasH,data.x2*canvasW,data.y2*canvasH,data.c,data.s,!!data.f,data.o);
    }
    else if(data.type==='txt'&&data.sid&&data.sid!==myId){
        const rc=getOrCreateRemoteCanvas(data.sid);
        rc.ctx.save();rc.ctx.globalAlpha=data.o||1;rc.ctx.font=`${data.s}px sans-serif`;rc.ctx.fillStyle=data.c;rc.ctx.fillText(data.t,data.x*canvasW,data.y*canvasH);rc.ctx.restore();
    }
    else if(data.type==='cur'){
        cursorTargets[data.id]={x:data.x,y:data.y,c:data.c,n:data.n,ls:Date.now()};
    }
    else if(data.type==='curL'){delete cursorSmooth[data.id];delete cursorTargets[data.id];}
    else if(data.type==='remoteClear'&&data.sid&&data.sid!==myId){
        if(remoteCanvases[data.sid])remoteCanvases[data.sid].ctx.clearRect(0,0,canvasW,canvasH);
    }
    else if(data.type==='fullSync'&&data.sid&&data.sid!==myId){
        const rc=getOrCreateRemoteCanvas(data.sid);
        const img=new Image();img.onload=()=>{rc.ctx.clearRect(0,0,canvasW,canvasH);rc.ctx.drawImage(img,0,0,canvasW,canvasH);};img.src=data.img;
    }
    else if(data.type==='reqSync'){sendFullSync();}
    else if(data.type==='chat'&&data.sid!==myId){addChat(data);}
    else if(data.type==='join'&&data.sid!==myId){sysMsg(data.n+' joined!');}
    else if(data.type==='leave'&&data.sid!==myId){sysMsg(data.n+' left');}
}

function sendFullSync(){
    const exp=document.createElement('canvas');exp.width=canvasW;exp.height=canvasH;const c=exp.getContext('2d');
    myLayers.forEach(l=>{if(l.visible){c.globalAlpha=l.opacity;c.drawImage(l.canvas,0,0);}});c.globalAlpha=1;
    broadcast({type:'fullSync',sid:myId,img:exp.toDataURL('image/png',0.7)});
}

// ===== COMMUNICATION =====
const bc = new BroadcastChannel('sadece_v5');
bc.onmessage = e=>handleMsg(e.data,'bc');

// Multi-peer connections (up to 11)
const peers = {}; // { peerId: { pc, dc } }
const MAX_PEERS = 11;

function broadcast(data){
    try{bc.postMessage(data);}catch(e){}
    for(const pid in peers){
        const dc=peers[pid].dc;
        if(dc&&dc.readyState==='open'){
            try{
                const str=JSON.stringify(data);
                if(str.length>MAX_MSG_SIZE)return; // Drop oversized
                if(str.length>60000){
                    // Chunk it
                    const mid=Math.random().toString(36).substr(2,6);
                    const chunks=Math.ceil(str.length/50000);
                    for(let i=0;i<chunks;i++)dc.send(JSON.stringify({type:'_chunk',mid,i,tot:chunks,d:str.substr(i*50000,50000)}));
                } else dc.send(str);
            }catch(e){}
        }
    }
}

// Chunk reassembly
const chunkBufs={};
function processChunk(data,peerId){
    const key=peerId+'_'+data.mid;
    if(!chunkBufs[key])chunkBufs[key]={parts:[],total:data.tot,time:Date.now()};
    chunkBufs[key].parts[data.i]=data.d;
    if(chunkBufs[key].parts.filter(p=>p).length===chunkBufs[key].total){
        const full=chunkBufs[key].parts.join('');delete chunkBufs[key];
        try{handleMsg(JSON.parse(full),peerId);}catch(e){}
    }
}
// Clean old chunks
setInterval(()=>{const now=Date.now();for(const k in chunkBufs)if(now-chunkBufs[k].time>15000)delete chunkBufs[k];},10000);

// ===== WEBRTC MULTI-PEER =====
const rtcCfg={iceServers:[{urls:'stun:stun.l.google.com:19302'},{urls:'stun:stun1.l.google.com:19302'},{urls:'stun:stun2.l.google.com:19302'},{urls:'stun:stun3.l.google.com:19302'}]};

const modal=document.getElementById('modal');
const statusEl=document.getElementById('connectionStatus');

document.getElementById('connectBtn').addEventListener('click',()=>{
    modal.classList.remove('hidden');
    document.getElementById('choiceView').style.display='block';
    document.getElementById('hostView').style.display='none';
    document.getElementById('joinView').style.display='none';
    document.getElementById('backToChoice').style.display='none';
});
document.getElementById('closeModalBtn').addEventListener('click',()=>modal.classList.add('hidden'));
document.getElementById('backToChoice').addEventListener('click',()=>{
    document.getElementById('choiceView').style.display='block';
    document.getElementById('hostView').style.display='none';
    document.getElementById('joinView').style.display='none';
    document.getElementById('backToChoice').style.display='none';
});

// === HOST: Create Room ===
document.getElementById('createBtn').addEventListener('click', async()=>{
    document.getElementById('choiceView').style.display='none';
    document.getElementById('hostView').style.display='block';
    document.getElementById('backToChoice').style.display='inline-block';

    // Create a new peer connection for this friend
    const peerId='peer_'+Date.now();
    const pc=new RTCPeerConnection(rtcCfg);
    const dc=pc.createDataChannel('draw',{ordered:true});

    peers[peerId]={pc,dc:null};

    dc.onopen=()=>{
        peers[peerId].dc=dc;
        statusEl.textContent='🟢 '+Object.values(peers).filter(p=>p.dc&&p.dc.readyState==='open').length+' connected';
        statusEl.style.color='#4ecca3';
        showToast('🟢 Friend connected!');
        sysMsg('A friend connected!');
        broadcast({type:'join',sid:myId,n:myName});
        setTimeout(()=>broadcast({type:'reqSync'}),500);
    };
    dc.onmessage=e=>{
        try{
            const d=JSON.parse(e.data);
            if(d.type==='_chunk'){processChunk(d,peerId);return;}
            if(e.data.length>MAX_MSG_SIZE)return; // DDoS protection
            handleMsg(d,peerId);
            // Relay to other peers (mesh network)
            for(const pid in peers){
                if(pid!==peerId&&peers[pid].dc&&peers[pid].dc.readyState==='open'){
                    try{peers[pid].dc.send(e.data);}catch(ex){}
                }
            }
        }catch(ex){}
    };
    dc.onclose=()=>{statusEl.textContent='🟡 '+(Object.values(peers).filter(p=>p.dc&&p.dc.readyState==='open').length)+' connected';sysMsg('A friend disconnected');};

    const offer=await pc.createOffer();
    await pc.setLocalDescription(offer);
    await waitICE(pc);

    document.getElementById('hostCode').value=btoa(JSON.stringify(pc.localDescription));
    statusEl.textContent='Waiting for friends...';

    // Store PC for answer
    document.getElementById('acceptFriendReply').onclick=async()=>{
        try{
            const ans=JSON.parse(atob(document.getElementById('hostAnswerInput').value.trim()));
            await pc.setRemoteDescription(new RTCSessionDescription(ans));
            document.getElementById('hostAnswerInput').value='';
            showToast('✅ Connecting...');
        }catch(ex){showToast('❌ Invalid reply code!');}
    };
});

document.getElementById('copyHostCode').addEventListener('click',()=>{
    navigator.clipboard.writeText(document.getElementById('hostCode').value).then(()=>{
        document.getElementById('copyHostCode').textContent='✅ Copied!';
        setTimeout(()=>document.getElementById('copyHostCode').textContent='📋 Copy My Code',2000);
    });
});

// === JOIN: Join Room ===
document.getElementById('joinBtn').addEventListener('click',()=>{
    document.getElementById('choiceView').style.display='none';
    document.getElementById('joinView').style.display='block';
    document.getElementById('joinStep2').style.display='none';
    document.getElementById('backToChoice').style.display='inline-block';
});

document.getElementById('processJoinCode').addEventListener('click', async()=>{
    const val=document.getElementById('joinOfferInput').value.trim();
    if(!val){showToast('Paste the host code first!');return;}
    try{
        const offer=JSON.parse(atob(val));
        const peerId='host_'+Date.now();
        const pc=new RTCPeerConnection(rtcCfg);

        peers[peerId]={pc,dc:null};

        pc.ondatachannel=e=>{
            const dc=e.channel;
            peers[peerId].dc=dc;
            dc.onopen=()=>{
                statusEl.textContent='🟢 Connected!';statusEl.style.color='#4ecca3';
                modal.classList.add('hidden');
                showToast('🟢 Connected!');sysMsg('Connected to room!');
                broadcast({type:'join',sid:myId,n:myName});
                setTimeout(()=>broadcast({type:'reqSync'}),800);
                if(!syncInt)syncInt=setInterval(sendFullSync,12000);
            };
            dc.onmessage=ev=>{
                try{
                    const d=JSON.parse(ev.data);
                    if(d.type==='_chunk'){processChunk(d,peerId);return;}
                    if(ev.data.length>MAX_MSG_SIZE)return;
                    handleMsg(d,peerId);
                }catch(ex){}
            };
            dc.onclose=()=>{statusEl.textContent='🔴 Disconnected';statusEl.style.color='#e94560';sysMsg('Disconnected');};
        };

        await pc.setRemoteDescription(new RTCSessionDescription(offer));
        const answer=await pc.createAnswer();
        await pc.setLocalDescription(answer);
        await waitICE(pc);

        document.getElementById('joinAnswerOutput').value=btoa(JSON.stringify(pc.localDescription));
        document.getElementById('joinStep2').style.display='block';
        statusEl.textContent='Send reply back to host...';
    }catch(ex){showToast('❌ Invalid code!');console.error(ex);}
});

document.getElementById('copyJoinAnswer').addEventListener('click',()=>{
    navigator.clipboard.writeText(document.getElementById('joinAnswerOutput').value).then(()=>{
        document.getElementById('copyJoinAnswer').textContent='✅ Copied!';
        setTimeout(()=>document.getElementById('copyJoinAnswer').textContent='📋 Copy My Reply',2000);
    });
});

function waitICE(pc){return new Promise(r=>{if(pc.iceGatheringState==='complete')return r();pc.addEventListener('icegatheringstatechange',()=>{if(pc.iceGatheringState==='complete')r();});setTimeout(r,5000);});}

// ===== PERIODIC SYNC =====
let syncInt=null;
setInterval(()=>{
    const connected=Object.values(peers).some(p=>p.dc&&p.dc.readyState==='open');
    if(connected&&!syncInt)syncInt=setInterval(sendFullSync,12000);
    if(!connected&&syncInt){clearInterval(syncInt);syncInt=null;}
},5000);

// Sync on tab focus
document.addEventListener('visibilitychange',()=>{
    if(!document.hidden&&appStarted){
        const connected=Object.values(peers).some(p=>p.dc&&p.dc.readyState==='open');
        if(connected)broadcast({type:'reqSync'});
    }
});

// Keep-alive
setInterval(()=>{if(appStarted)broadcast({type:'cur',id:myId,x:(myCursorPos.x||0)/canvasW,y:(myCursorPos.y||0)/canvasH,c:myColor,n:myName});},3000);

// ===== INIT =====
function initApp(){
    resizeAll();initMyLayers();saveUndo();updateSizePreview();
    statusEl.textContent='Offline — click 🌐';
    sysMsg('Welcome '+myName+'! Click 🌐 to connect.');
    // Auto-save
    setInterval(()=>{try{const e=document.createElement('canvas');e.width=canvasW;e.height=canvasH;const c=e.getContext('2d');myLayers.forEach(l=>{if(l.visible){c.globalAlpha=l.opacity;c.drawImage(l.canvas,0,0);}});localStorage.setItem('st_auto',e.toDataURL('image/png',0.5));localStorage.setItem('st_auto_t',''+Date.now());}catch(e){}},30000);
    // Load autosave
    const as=localStorage.getItem('st_auto'),at=localStorage.getItem('st_auto_t');
    if(as&&at&&Date.now()-parseInt(at)<3600000){const img=new Image();img.onload=()=>{getActiveCtx().drawImage(img,0,0,canvasW,canvasH);saveUndo();sysMsg('Restored autosave');};img.src=as;}
}
requestAnimationFrame(renderCursors);
</script>
