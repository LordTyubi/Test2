// ===== DRAW FUNCTIONS =====
function drawLine(ctx,x1,y1,x2,y2,color,size,eraser,opacity){
    ctx.save();ctx.globalAlpha=opacity??1;ctx.lineCap='round';ctx.lineJoin='round';ctx.lineWidth=size;
    if(dashMode&&!eraser)ctx.setLineDash([size*2,size*1.5]);
    if(eraser){ctx.globalCompositeOperation='destination-out';ctx.strokeStyle='rgba(0,0,0,1)';}
    else{ctx.globalCompositeOperation='source-over';ctx.strokeStyle=color;}
    ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke();ctx.restore();
}
function drawSpray(ctx,x,y,color,size,opacity){
    ctx.save();ctx.globalAlpha=opacity??1;ctx.fillStyle=color;
    for(let i=0;i<size*2;i++){const a=Math.random()*Math.PI*2,r=Math.random()*size;ctx.fillRect(x+Math.cos(a)*r,y+Math.sin(a)*r,1,1);}
    ctx.restore();
}
function drawShape(ctx,tool,x1,y1,x2,y2,color,size,fill,opacity){
    ctx.save();ctx.globalAlpha=opacity??1;ctx.strokeStyle=color;ctx.fillStyle=color;ctx.lineWidth=size;ctx.lineCap='round';ctx.lineJoin='round';
    if(dashMode)ctx.setLineDash([size*2,size*1.5]);
    if(tool==='rect'){const rx=Math.min(x1,x2),ry=Math.min(y1,y2),rw=Math.abs(x2-x1),rh=Math.abs(y2-y1);if(fill)ctx.fillRect(rx,ry,rw,rh);ctx.strokeRect(rx,ry,rw,rh);}
    else if(tool==='circle'){const cx=(x1+x2)/2,cy=(y1+y2)/2,rx=Math.abs(x2-x1)/2,ry=Math.abs(y2-y1)/2;ctx.beginPath();ctx.ellipse(cx,cy,Math.max(rx,1),Math.max(ry,1),0,0,Math.PI*2);if(fill)ctx.fill();ctx.stroke();}
    else if(tool==='line'){ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke();}
    ctx.restore();
}
function floodFill(ctx,sx,sy,fillColor){
    const w=canvasW,h=canvasH;sx=Math.floor(sx);sy=Math.floor(sy);
    if(sx<0||sx>=w||sy<0||sy>=h)return;
    const id=ctx.getImageData(0,0,w,h),d=id.data;
    const ti=(sy*w+sx)*4,tr=d[ti],tg=d[ti+1],tb=d[ti+2],ta=d[ti+3];
    const fc=hexToRgb(fillColor);if(tr===fc.r&&tg===fc.g&&tb===fc.b&&ta===255)return;
    const stack=[[sx,sy]];let safety=0;
    while(stack.length&&safety<w*h){safety++;const[px,py]=stack.pop();if(px<0||px>=w||py<0||py>=h)continue;
    const i=(py*w+px)*4;if(Math.abs(d[i]-tr)>30||Math.abs(d[i+1]-tg)>30||Math.abs(d[i+2]-tb)>30||Math.abs(d[i+3]-ta)>30)continue;
    d[i]=fc.r;d[i+1]=fc.g;d[i+2]=fc.b;d[i+3]=255;stack.push([px+1,py],[px-1,py],[px,py+1],[px,py-1]);}
    ctx.putImageData(id,0,0);
}
function hexToRgb(h){if(h.length===4)h='#'+h[1]+h[1]+h[2]+h[2]+h[3]+h[3];return{r:parseInt(h.slice(1,3),16),g:parseInt(h.slice(3,5),16),b:parseInt(h.slice(5,7),16)};}

function getPos(e){const r=containerEl.getBoundingClientRect();const cx=e.touches?e.touches[0].clientX:e.clientX;const cy=e.touches?e.touches[0].clientY:e.clientY;return{x:cx-r.left,y:cy-r.top};}

let pointBuf=[];

function startDraw(e){
    if(e.button===1||e.button===2)return; // BLOCK middle & right
    e.preventDefault();if(!appStarted)return;
    const p=getPos(e);isDrawing=true;lastX=p.x;lastY=p.y;startX=p.x;startY=p.y;pointBuf=[p];
    if(currentTool==='fillBucket'){saveUndo();floodFill(getActiveCtx(),p.x,p.y,currentColor);isDrawing=false;return;}
    if(currentTool==='eyedropper'){eyedrop(p.x,p.y);isDrawing=false;return;}
    if(currentTool==='text'){addText(p.x,p.y);isDrawing=false;return;}
    if(currentTool==='brush'||currentTool==='eraser'||currentTool==='spray'){
        saveUndo();
        if(currentTool==='spray'){drawSpray(getActiveCtx(),p.x,p.y,currentColor,currentSize,currentOpacity);broadcast({type:'spray',sid:myId,x:p.x/canvasW,y:p.y/canvasH,c:currentColor,s:currentSize,o:currentOpacity});}
        else{drawLine(getActiveCtx(),p.x,p.y,p.x,p.y,currentColor,currentSize,currentTool==='eraser',currentOpacity);
        broadcast({type:'d',sid:myId,x1:p.x/canvasW,y1:p.y/canvasH,x2:p.x/canvasW,y2:p.y/canvasH,c:currentColor,s:currentSize,e:currentTool==='eraser'?1:0,o:currentOpacity});
        if(mirrorMode){const mx=canvasW-p.x;drawLine(getActiveCtx(),mx,p.y,mx,p.y,currentColor,currentSize,currentTool==='eraser',currentOpacity);broadcast({type:'d',sid:myId,x1:mx/canvasW,y1:p.y/canvasH,x2:mx/canvasW,y2:p.y/canvasH,c:currentColor,s:currentSize,e:currentTool==='eraser'?1:0,o:currentOpacity});}}
    } else saveUndo();
}

let myCursorIn=false, myCursorPos={x:-99,y:-99};
let lastCB=0;

function doDraw(e){
    if(e.button===1)return;
    e.preventDefault();if(!appStarted)return;
    const p=getPos(e);myCursorPos=p;myCursorIn=true;
    const now=performance.now();
    if(now-lastCB>8){lastCB=now;broadcast({type:'cur',id:myId,x:p.x/canvasW,y:p.y/canvasH,c:myColor,n:myName});}
    if(!isDrawing)return;
    if(currentTool==='brush'||currentTool==='eraser'){
        pointBuf.push(p);if(pointBuf.length>3)pointBuf.shift();
        const a=pointBuf.reduce((ac,pt)=>({x:ac.x+pt.x/pointBuf.length,y:ac.y+pt.y/pointBuf.length}),{x:0,y:0});
        drawLine(getActiveCtx(),lastX,lastY,a.x,a.y,currentColor,currentSize,currentTool==='eraser',currentOpacity);
        broadcast({type:'d',sid:myId,x1:lastX/canvasW,y1:lastY/canvasH,x2:a.x/canvasW,y2:a.y/canvasH,c:currentColor,s:currentSize,e:currentTool==='eraser'?1:0,o:currentOpacity});
        if(mirrorMode){const mx1=canvasW-lastX,mx2=canvasW-a.x;drawLine(getActiveCtx(),mx1,lastY,mx2,a.y,currentColor,currentSize,currentTool==='eraser',currentOpacity);broadcast({type:'d',sid:myId,x1:mx1/canvasW,y1:lastY/canvasH,x2:mx2/canvasW,y2:a.y/canvasH,c:currentColor,s:currentSize,e:currentTool==='eraser'?1:0,o:currentOpacity});}
        lastX=a.x;lastY=a.y;
    } else if(currentTool==='spray'){
        drawSpray(getActiveCtx(),p.x,p.y,currentColor,currentSize,currentOpacity);
        broadcast({type:'spray',sid:myId,x:p.x/canvasW,y:p.y/canvasH,c:currentColor,s:currentSize,o:currentOpacity});
        lastX=p.x;lastY=p.y;
    } else {
        shapeCtx.clearRect(0,0,canvasW,canvasH);
        drawShape(shapeCtx,currentTool,startX,startY,p.x,p.y,currentColor,currentSize,shapeFill,currentOpacity);
    }
}

function endDraw(e){
    if(!isDrawing)return;isDrawing=false;pointBuf=[];
    if(currentTool==='rect'||currentTool==='circle'||currentTool==='line'){
        let p;if(e.changedTouches){const r=containerEl.getBoundingClientRect();p={x:e.changedTouches[0].clientX-r.left,y:e.changedTouches[0].clientY-r.top};}else p=getPos(e);
        shapeCtx.clearRect(0,0,canvasW,canvasH);
        drawShape(getActiveCtx(),currentTool,startX,startY,p.x,p.y,currentColor,currentSize,shapeFill,currentOpacity);
        broadcast({type:'sh',sid:myId,t:currentTool,x1:startX/canvasW,y1:startY/canvasH,x2:p.x/canvasW,y2:p.y/canvasH,c:currentColor,s:currentSize,f:shapeFill?1:0,o:currentOpacity});
        if(mirrorMode){const mx1=canvasW-startX,mx2=canvasW-p.x;drawShape(getActiveCtx(),currentTool,mx1,startY,mx2,p.y,currentColor,currentSize,shapeFill,currentOpacity);broadcast({type:'sh',sid:myId,t:currentTool,x1:mx1/canvasW,y1:startY/canvasH,x2:mx2/canvasW,y2:p.y/canvasH,c:currentColor,s:currentSize,f:shapeFill?1:0,o:currentOpacity});}
    }
}

function eyedrop(x,y){
    const exp=document.createElement('canvas');exp.width=canvasW;exp.height=canvasH;const c=exp.getContext('2d');
    c.fillStyle='#fff';c.fillRect(0,0,canvasW,canvasH);
    myLayers.forEach(l=>{if(l.visible){c.globalAlpha=l.opacity;c.drawImage(l.canvas,0,0);}});
    for(const p in remoteCanvases){c.globalAlpha=1;c.drawImage(remoteCanvases[p].canvas,0,0);}
    const px=c.getImageData(Math.floor(x),Math.floor(y),1,1).data;
    currentColor='#'+[px[0],px[1],px[2]].map(v=>v.toString(16).padStart(2,'0')).join('');
    colorPicker.value=currentColor;updateSizePreview();showToast('🎨 '+currentColor);setTool('brush');
}

function addText(x,y){const t=prompt('Enter text:');if(!t)return;saveUndo();const ctx=getActiveCtx();ctx.save();ctx.globalAlpha=currentOpacity;ctx.font=`${currentSize*3}px sans-serif`;ctx.fillStyle=currentColor;ctx.fillText(t,x,y);ctx.restore();broadcast({type:'txt',sid:myId,x:x/canvasW,y:y/canvasH,t,c:currentColor,s:currentSize*3,o:currentOpacity});}

